---
import "../styles/global.css";
import HorizonGradient from "../components/background/HorizonGradient.astro";
import LightCircles from "../components/background/LightCircles.astro";
import RainbowGradient from "../components/background/RainbowGradient.astro";
import LogoText from "../components/branding/LogoText.astro";
import Footer from "../components/navigation/Footer.astro";
import NavBar from "../components/navigation/NavBar.astro";

interface Props {
  description?: string;
  title: string;
}

const { description = "Jan Madeyski — full stack developer z ponad 10-letnim doświadczeniem w tworzeniu aplikacji internetowych.", title = "Start" } = Astro.props;
const pageTitle = `Madeyski.org | ${title}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta content="width=device-width" name="viewport" />
    <meta content={description} name="description" />
    <meta content="text/html; charset=utf-8" http-equiv="Content-Type" />
		<link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <link href={canonicalUrl} rel="canonical" />
		<title>{pageTitle}</title>

    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content="Madeyski.org" property="og:site_name" />
    <meta content="pl_PL" property="og:locale" />

    <meta content="summary" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
	</head>
	<body class="flex flex-col min-h-screen bg-gray-400">
    <HorizonGradient />
    <RainbowGradient />
    <LightCircles />
    <LogoText />
    <NavBar />

    <div class="mt-6 px-8 md:px-16 py-4 md:py-8 container w-full max-w-5xl mx-auto bg-white/60 backdrop-blur-lg rounded-3xl shadow-md/30">
      <slot />
    </div>

    <Footer />

    <script>
      import { clipboardHandler } from '../utils/clipboardHandler';
      clipboardHandler.init();
    </script>
	</body>
</html>

<style>
  @reference "tailwindcss";

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

  body {
    background-image: conic-gradient(from 180deg,
      var(--color-teal-200),
      var(--color-slate-400),
      var(--color-blue-200),
      var(--color-slate-400),
      var(--color-blue-200),
      var(--color-slate-400),
      var(--color-gray-200),
      var(--color-teal-200)
    );
  }
</style>
