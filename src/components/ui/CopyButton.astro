---
import { Check, Copy } from 'lucide-astro';

export interface Props {
  size?: number;
  text: string;
}

const { size = 16, text } = Astro.props;
---

<button
  class="copy-button group ml-2 p-1 text-gray-800 cursor-pointer rounded opacity-50 hover:opacity-100 hover:scale-105 transition-all duration-200"
  data-copy-text={text}
  title="Copy to clipboard"
>
  <Copy class="copy-icon group-[.copied]:hidden" size={size} />
  <Check class="check-icon hidden group-[.copied]:block group-[.copied]:text-green-600" size={size} />
</button>
